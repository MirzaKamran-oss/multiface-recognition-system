OUTPUT_DIR=outputs
MAX_FILE_SIZE_MB=10

# MySQL Settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=attendance_system
